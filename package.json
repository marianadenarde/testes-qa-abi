{
  "name": "serverest-cypress-tests",
  "version": "1.0.0",
  "description": "Testes automatizados E2E (frontend) e de API para a aplicação ServeRest, utilizando Cypress e JavaScript.",
  "private": true,
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test:e2e": "cypress run --spec \"cypress/e2e/frontend/**/*.cy.js\"",
    "test:api": "cypress run --spec \"cypress/e2e/api/**/*.cy.js\"",
    "test:all": "cypress run"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "cypress": "^13.13.0"
  }
}
